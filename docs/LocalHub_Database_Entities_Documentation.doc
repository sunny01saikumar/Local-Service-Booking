<div class="cover-page">
    <div class="cover-title">LocalHub</div>
    <div class="cover-subtitle">Hyperlocal Service Booking Platform<br>Database Entity Architecture & Data Model</div>
    <div class="cover-meta">
        <strong>Author:</strong> Lead Architect Agent<br>
        <strong>Engine:</strong> PostgreSQL (Neon / Production)<br>
        <strong>Date:</strong> July 2026<br>
        <strong>Status:</strong> Approved Schema Specification
    </div>
